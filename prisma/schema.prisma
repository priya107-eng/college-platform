generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  rating      Float
  fees        String
  placements  String
  image       String
  description String
  courses     String[]
}